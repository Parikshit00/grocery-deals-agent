# Environment configuration. Copy to .env and adjust values.

# --- App ---
APP_ENV=local
LOG_LEVEL=INFO

# --- Network ---
API_HOST=0.0.0.0
API_PORT=28734
FRONTEND_PORT=28735

# --- Postgres (pgvector) ---
POSTGRES_USER=angebot
POSTGRES_PASSWORD=angebot
POSTGRES_DB=angebot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Reasoning LLM (local, OpenAI-compatible) ---
# Default: Ollama. For vLLM, use http://localhost:28800/v1 and the served model id.
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=EMPTY
LLM_MODEL=qwen3.5:latest

# --- Vision / fallback model (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
VISION_MODEL=qwen2.5vl:7b
FALLBACK_CHAT_MODEL=qwen3.5:latest
EMBEDDING_MODEL=bge-m3

# --- Data sources ---
MARKTGURU_BASE_URL=https://api.marktguru.de/api/v1
MARKTGURU_WEB_URL=https://www.marktguru.de
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
HTTP_RATE_LIMIT_PER_MIN=30

# --- Offer cache ---
OFFER_TTL_HOURS=24

# --- MCP servers ---
MCP_HOST=127.0.0.1
MCP_BROWSE_PORT=28810
MCP_GEO_PORT=28811
MCP_BROWSE_URL=http://127.0.0.1:28810/mcp
MCP_GEO_URL=http://127.0.0.1:28811/mcp
