# App
APP_ENV=local
LOG_LEVEL=INFO

# Postgres
POSTGRES_USER=angebot
POSTGRES_PASSWORD=angebot
POSTGRES_DB=angebot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Reasoning LLM (local vLLM, OpenAI-compatible) - Qwen3-30B-A3B-Thinking on GPU 0
LLM_BASE_URL=http://localhost:28800/v1
LLM_API_KEY=EMPTY
LLM_MODEL=qwen3-thinking

# Vision VLM (local vLLM, OpenAI-compatible) - Qwen3-VL-32B-Instruct on GPU 1
VLM_BASE_URL=http://localhost:28801/v1
VISION_MODEL=qwen3-vl

# Embeddings (sentence-transformers, local)
EMBEDDING_MODEL=BAAI/bge-m3

# --- Geocoding ---
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# HuggingFace
HF_TOKEN=
