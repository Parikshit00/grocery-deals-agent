# Environment configuration. Copy to .env and adjust values.

# --- App ---
APP_ENV=local
LOG_LEVEL=INFO

# --- Network ---
API_HOST=0.0.0.0
API_PORT=28734
FRONTEND_PORT=28735

# --- Postgres (pgvector) ---
POSTGRES_USER=angebot
POSTGRES_PASSWORD=angebot
POSTGRES_DB=angebot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Reasoning LLM (vLLM, OpenAI-compatible) ---
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=EMPTY
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# --- Vision / fallback model (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
VISION_MODEL=qwen2.5vl
FALLBACK_CHAT_MODEL=llama3.1
EMBEDDING_MODEL=bge-m3

# --- Data sources ---
MARKTGURU_BASE_URL=https://api.marktguru.de/api/v1
HTTP_RATE_LIMIT_PER_MIN=30

# --- Offer cache ---
OFFER_TTL_HOURS=24
